<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%-5level] %msg%n</pattern>
            <!-- Without this, logback writes using the JVM's default charset
                 (Cp1252 on Windows), which mangles the box-drawing and check-mark
                 icons used in our log banners. -->
            <charset>UTF-8</charset>
        </encoder>
        <target>System.err</target>
    </appender>

    <!-- Silence Hadoop's very noisy internal loggers -->
    <logger name="org.apache.hadoop"        level="WARN"/>
    <logger name="org.apache.parquet"       level="WARN"/>
    <logger name="org.apache.avro"          level="WARN"/>

    <!-- Our app logs at INFO -->
    <logger name="com.tizitec.parquet2csv"  level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
